---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostArticle from '../../../components/PostArticle.astro';
import {
  DEFAULT_LANGUAGE,
  getPostBySlug,
  getPostsByTranslationGroup,
} from '../../../lib/db';

const { lang, slug } = Astro.params;
if (!slug || !lang) return new Response('Not found', { status: 404 });

if (!/^[a-z]{2}(-[A-Z]{2})?$/.test(lang)) {
  return new Response('Not found', { status: 404 });
}

const db = Astro.locals.runtime.env.DB;
const user = Astro.locals.user;
const defaultLanguage = Astro.locals.runtime.env.DEFAULT_LANGUAGE ?? DEFAULT_LANGUAGE;

if (lang === defaultLanguage) {
  return Astro.redirect(`/blog/${slug}`);
}

const post = await getPostBySlug(db, slug, lang);

const canSee =
  post &&
  (post.status === 'published' || (user && (user.role === 'admin' || user.id === post.userId)));

if (!canSee) return new Response('Not found', { status: 404 });

const siblings = post.translationGroupId
  ? await getPostsByTranslationGroup(db, post.translationGroupId)
  : [post];
---

<BaseLayout title={post.title} description={post.description}>
  <PostArticle post={post} siblings={siblings} defaultLanguage={defaultLanguage} />
</BaseLayout>
